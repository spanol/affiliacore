{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "AdminMetric": {
      "title": "Admin Metric",
      "description": "Key performance metrics for the admin dashboard",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "trend": { "type": "number" },
        "icon": { "type": "string" }
      },
      "required": ["label", "value"]
    },
    "ClientInfo": {
      "title": "Client Info",
      "description": "Information displayed to clients",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["title", "content"]
    },
    "AppSetting": {
      "title": "App Setting",
      "description": "Global application settings and API keys",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" },
        "description": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "value"]
    },
    "AffiliateConfig": {
      "title": "Affiliate Config",
      "description": "Configuration per affiliate for CPA and REV%",
      "type": "object",
      "properties": {
        "affiliateId": { "type": "string" },
        "cpaValue": { "type": "number" },
        "revPercentage": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["affiliateId", "cpaValue", "revPercentage"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/admin_metrics/{metricId}": {
      "schema": "AdminMetric",
      "description": "Metrics for admin dashboard"
    },
    "/client_info/{infoId}": {
      "schema": "ClientInfo",
      "description": "Information for client dashboard"
    },
    "/settings/{settingId}": {
      "schema": "AppSetting",
      "description": "Global settings accessible only by admin"
    },
    "/affiliate_configs/{affiliateId}": {
      "schema": "AffiliateConfig",
      "description": "Configurations for affiliates"
    }
  }
}
