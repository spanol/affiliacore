node_modules/
build/
dist/
coverage/

# Versão gerada no build (scripts/gen-version.mjs). Não versionar — muda a cada
# build/deploy; o conteúdo é derivado (carimbo de tempo + commit).
public/version.json
.DS_Store
*.log
.env*
!.env.example

# Firebase Admin service account key (NEVER commit)
# Padrão amplo: cobre a chave da instância 0 (service-account.json) E as chaves
# por instância do provisionamento white-label (service-account.<instancia>.json).
service-account*.json
*-firebase-adminsdk-*.json

# OTG approved-affiliates snapshots — contêm PII (e-mail/telefone). Manter local;
# versiona-se só o script e o README (ver scripts/otg-approved/README.md).
scripts/otg-approved/snapshot-*.json

# Firebase Hosting deploy cache
.firebase/

# Runtime local da demo mockada (credenciais, logs e metadados gerados pelo
# script 1-clique). Nunca versionar.
.demo-runtime/
