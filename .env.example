# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Project Configuration
VITE_FIREBASE_PROJECT_ID=agencia-boost

# Affiliate API Configuration
# Base URL is read server-side (not a secret). The x-api-key MUST stay server-only
# (no VITE_ prefix) so it is never embedded in the browser bundle — the client talks
# to the partner API exclusively through the authenticated /api/external proxy.
VITE_AFFILIATE_API_BASE_URL=https://affiliate-api-prd.partnersotg.com
AFFILIATE_API_KEY=

# P2 (produtização): módulo OTG por instância. 'false' = instância OTG-free
# (white-label): rotas OTG respondem 503, menu/rota do Roster somem, ranking e
# dashboards rodam 100% em casas manuais. Ausente/qualquer outro valor = ligado.
# VITE_ de propósito: a MESMA env vale no bundle (build) e no servidor (runtime).
# Não é credencial. Fonte única: src/lib/instance.ts.
VITE_OTG_ENABLED=

# P3/P4.1 (produtização): marca por instância (white-label). Ausência de TODAS =
# marca do PRODUTO (AffiliaCore — inversão 2026-07-05; a instância Boost do Carlos
# é pinada por env no apphosting.yaml). VITE_BRAND_SHORT entra no meio de frase
# tratado no FEMININO ("a {short} calcula...") — escolha um nome que caiba.
# Logo/favicon são URLs (Storage da instância, CDN ou caminho servido de /public).
# Fonte única: src/lib/branding.ts (título+favicon aplicados em runtime no boot).
VITE_BRAND_NAME=
VITE_BRAND_SHORT=
VITE_BRAND_LOGO_URL=
VITE_BRAND_FAVICON_URL=

# P3.1 (produtização): TEMA por instância. ACCENT = 1 hex (ex. #E11D48) — vira a
# escala accent-50..950 inteira + cor de texto sobre o accent (contraste WCAG),
# aplicada em runtime (src/lib/theming.ts; classes accent-* do Tailwind viram
# var()). SURFACE = hex do navy de superfície (--color-brand; a variante clara é
# derivada). Ausência = tema do produto (amber/navy — o visual da Boost).
# ATENÇÃO: amber-* continua existindo como cor de AVISO (pendências/alertas) e
# NÃO muda com o tema — só a cor de MARCA (accent-*) muda.
VITE_BRAND_ACCENT=
VITE_BRAND_SURFACE=

# P3.2 (produtização): ESTILO das superfícies de marca. 'glass' (default — o look
# da Boost: fills translúcidos + backdrop-blur no header, cards de auth, LP,
# banner e thead sticky) ou 'solid' (fills opacos, blur zerado — look corporativo
# limpo). Mesma mecânica runtime do accent (src/lib/theming.ts sobrescreve os
# tokens --color-glass-*/--blur-glass-* do index.css). Scrim de modal não muda.
VITE_BRAND_STYLE=

# Secret do cron interno (alto-entropia). Gateia (header x-cron-secret) os endpoints que
# um Cloud Scheduler chama SEM token admin Firebase. Sem ele as rotas respondem 503.
#   - POST /api/internal/daily-ranking     (~14h30 BR: gera ranking do dia + avisa admins)
#   - POST /api/internal/analytics-refresh (atualiza o funil v1 da OTG: cliques/cadastros)
# Gere com (Windows tem Node, não openssl):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RANKING_CRON_SECRET=

# E-mail do admin MASTER que recebe o lembrete diário do ranking (popup). Vazio =
# lembrete vai a TODOS os admins (fallback). Comparação case-insensitive.
MASTER_ADMIN_EMAIL=

# OTG · provisionamento (links.otgpartners.com.br → Supabase). Server-only.
# Usado pelo pull automático do roster de aprovados (POST /api/pending-affiliates/refresh
# → pending_affiliates). A anon key é PÚBLICA (vem no bundle do site de links); o que
# protege o roster é o RLS + o login da agência (email/senha — esses SÃO sensíveis).
OTG_LINKS_SUPABASE_URL=https://pxzqtmnegzygikwvdaqj.supabase.co
OTG_LINKS_SUPABASE_ANON_KEY=
OTG_LINKS_EMAIL=
OTG_LINKS_PASSWORD=

# OTG · v1 ANALÍTICA da agência (cliques + funil inicial + NGR). Server-only.
# Usado por POST /api/analytics/refresh → GET {BASE}/api/v1/agency/{casa}-analytics.
# É o 3º backend da OTG (≠ relatório v2 / ≠ provisionamento Supabase). Traz os afiliados
# só-funil (clique/cadastro sem comissão) que a v2 esconde. Ver SPIKE-OTG-V1-ANALYTICS.md.
# Base = MESMO host da v2. Param confirmado: scope=AFFILIATES (≠ 'affiliate', que dá 400).
OTG_DASH_API_BASE=https://affiliate-api-prd.partnersotg.com
#
# AUTH DURÁVEL (preferido). Contrato capturado 2026-06-25:
#   POST /api/v1/auth/login { email, password, deviceToken } → { data: { access_token } }.
# O servidor loga sob demanda e cacheia o access_token (~15 min) em memória. O 2FA é
# PULADO pelo `deviceToken` (= localStorage `2fa:login.token`, TTL ~8h). Você só re-troca
# o DEVICE_TOKEN a cada ~8h (no console do dashboard logado pós-2FA:
#   JSON.parse(localStorage.getItem('2fa:login')).token  ).
OTG_DASH_EMAIL=
OTG_DASH_PASSWORD=
OTG_DASH_DEVICE_TOKEN=
# OVERRIDE manual (opcional): cole um access_token pós-2FA (TTL ~15 min). Se setado, tem
# prioridade sobre o login durável acima — útil p/ teste rápido. copy(localStorage.getItem('access_token')).
OTG_DASH_ACCESS_TOKEN=
# casas a puxar (slugs separados por vírgula); default: sportingbet,superbet. NOTA: em
# 2026-06 só `sportingbet-analytics` existe — `superbet-analytics` dá 404 (tratado como
# casa "indisponível", não derruba o pull); ambas constam em /api/v1/betting-houses.
OTG_DASH_HOUSES=sportingbet,superbet
