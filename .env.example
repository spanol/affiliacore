# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Project Configuration
VITE_FIREBASE_PROJECT_ID=agencia-boost

# Affiliate API Configuration
# Base URL is read server-side (not a secret). The x-api-key MUST stay server-only
# (no VITE_ prefix) so it is never embedded in the browser bundle — the client talks
# to the partner API exclusively through the authenticated /api/external proxy.
VITE_AFFILIATE_API_BASE_URL=https://affiliate-api-prd.partnersotg.com
AFFILIATE_API_KEY=

# Secret do cron interno (alto-entropia). Habilita POST /api/internal/daily-ranking,
# que um Cloud Scheduler chama 1×/dia (~14h30 BR) com o header x-cron-secret p/ gerar
# o ranking do dia E avisar os admins (popup). Sem ele a rota responde 503 (feature off).
# Gere com (Windows tem Node, não openssl):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RANKING_CRON_SECRET=

# E-mail do admin MASTER que recebe o lembrete diário do ranking (popup). Vazio =
# lembrete vai a TODOS os admins (fallback). Comparação case-insensitive.
MASTER_ADMIN_EMAIL=

# OTG · provisionamento (links.otgpartners.com.br → Supabase). Server-only.
# Usado pelo pull automático do roster de aprovados (POST /api/pending-affiliates/refresh
# → pending_affiliates). A anon key é PÚBLICA (vem no bundle do site de links); o que
# protege o roster é o RLS + o login da agência (email/senha — esses SÃO sensíveis).
OTG_LINKS_SUPABASE_URL=https://pxzqtmnegzygikwvdaqj.supabase.co
OTG_LINKS_SUPABASE_ANON_KEY=
OTG_LINKS_EMAIL=
OTG_LINKS_PASSWORD=

# OTG · v1 ANALÍTICA da agência (cliques + funil inicial + NGR). Server-only.
# Usado por POST /api/analytics/refresh → GET {BASE}/api/v1/agency/{casa}-analytics.
# É o 3º backend da OTG (≠ relatório v2 / ≠ provisionamento Supabase). Traz os afiliados
# só-funil (clique/cadastro sem comissão) que a v2 esconde. Ver SPIKE-OTG-V1-ANALYTICS.md.
# ATENÇÃO: o dashboard partners.grupootg.com tem 2FA → NÃO há password-grant server-side;
# o ACCESS_TOKEN é um Bearer obtido PÓS-2FA (curto/expira) e colocado aqui/Secret Manager.
# (Quando capturarmos o endpoint de refresh, trocamos por refresh-token durável.)
OTG_DASH_API_BASE=
OTG_DASH_ACCESS_TOKEN=
# casas a puxar (slugs separados por vírgula); default: sportingbet,superbet
OTG_DASH_HOUSES=sportingbet,superbet
